# Shared password you give to new hires (also set in Vercel).
STOREFRONT_PASSWORD=

# Secret used to sign the session cookie.
# Generate with: openssl rand -base64 32
STOREFRONT_SESSION_SECRET=

# ============================================================================
# Email / form delivery — set up ONE of the options below.
# (If you set multiple, the storefront will send to each and succeed as long
#  as at least one accepts the submission.)
# ============================================================================

# ── Option A: Resend (https://resend.com) ───────────────────────────────────
# Sign up, verify a sending domain, then create an API key.
# Without a verified domain, STOREFRONT_FROM_EMAIL falls back to
# "Rain Storefront <onboarding@resend.dev>" which only delivers to the
# Resend account's own inbox.
STOREFRONT_RESEND_API_KEY=
STOREFRONT_NOTIFY_EMAIL=
STOREFRONT_FROM_EMAIL=

# ── Option B: Google Forms ──────────────────────────────────────────────────
# 1. Create a Google Form with the questions you want (e.g. Name, Email,
#    Phone, Address, Laptop, Requests, Reason, or a single "Details" field).
# 2. In Google Forms, turn on "Settings → Responses → Get email
#    notifications for new responses" so each submission emails you.
# 3. Open the form in PREVIEW (eye icon), then:
#      View source / DevTools → find each input's name="entry.XXXXXXXXXX"
#    and copy that for each question.
# 4. Get the submit URL: it looks like
#      https://docs.google.com/forms/d/e/<FORM_ID>/formResponse
#    (use the form preview's <form action="..."> attribute).
# 5. Set the URL plus the entry IDs you want to populate. Only the entries
#    you set will be sent; everything else is ignored.
STOREFRONT_GOOGLE_FORM_URL=
STOREFRONT_GOOGLE_FORM_ENTRY_NAME=
STOREFRONT_GOOGLE_FORM_ENTRY_EMAIL=
STOREFRONT_GOOGLE_FORM_ENTRY_PHONE=
STOREFRONT_GOOGLE_FORM_ENTRY_ADDRESS=
STOREFRONT_GOOGLE_FORM_ENTRY_LAPTOP=
STOREFRONT_GOOGLE_FORM_ENTRY_SCREEN_SIZE=
STOREFRONT_GOOGLE_FORM_ENTRY_REQUESTS=
STOREFRONT_GOOGLE_FORM_ENTRY_REASON=
# Or, for a "single long-answer" form, only set this one — it receives the
# entire request as plain text:
STOREFRONT_GOOGLE_FORM_ENTRY_SUMMARY=

# ── Option C: Any JSON form endpoint (e.g. Formspree) ───────────────────────
STOREFRONT_FORM_ENDPOINT=
